@inject NavigationManager Navigation

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">NeoHub</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="if (window.matchMedia('(max-width: 640.98px)').matches) document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Home">Home</MudNavLink>
        </div>

        <div class="nav-item px-3">
            <MudNavLink Href="connections" Icon="@Icons.Material.Filled.Cable">Connections</MudNavLink>
        </div>

        <div class="nav-item px-3">
            <MudNavLink Href="settings" Icon="@Icons.Material.Filled.Settings">Settings</MudNavLink>
        </div>

        <div class="nav-item px-3">
            <MudNavLink Href="diagnostics" Icon="@Icons.Material.Filled.BugReport">Diagnostics</MudNavLink>
        </div>

        <div class="nav-item px-3">
            <MudNavLink Href="dev-console" Icon="@Icons.Material.Filled.Terminal">Dev Console</MudNavLink>
        </div>
    </nav>
    <div class="nav-version" onclick="event.stopPropagation()">
        <div>GitHub @GithubShortHash · Build @BuildInfo.BuildNumber</div>
        <div>@BuildInfo.BuildTimeUtc.ToString("yyyy-MM-dd HH:mm") UTC · @BuildAge</div>
    </div>
</div>

@code {
    private static string GithubShortHash =>
        string.IsNullOrEmpty(BuildInfo.GitCommit)
            ? "unknown"
            : BuildInfo.GitCommit[..Math.Min(7, BuildInfo.GitCommit.Length)];

    private static string BuildAge
    {
        get
        {
            var age = DateTime.UtcNow - BuildInfo.BuildTimeUtc;
            return age.TotalHours < 48
                ? $"{(int)age.TotalHours}h ago"
                : $"{(int)age.TotalDays}d ago";
        }
    }
}


